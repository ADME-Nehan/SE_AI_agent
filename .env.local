# Server
PORT=3000

# Groq AI - no demo fallback in this project
GROQ_API_KEY=your_groq_api_key_here
# Recommended current Groq model. You can change this in Groq console if needed.
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Firebase Web App Config
# Get these from Firebase Console > Project settings > General > Your apps > Web app config
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=

# Optional Google Stitch UI generation
# Manual mode works without this. API mode needs STITCH_API_KEY and npm install @google/stitch-sdk.
STITCH_API_KEY=your_stitch_api_key_here
STITCH_BASE_URL=https://stitch.googleapis.com/mcp
